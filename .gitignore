# ─── FLUTTER — gerado automaticamente ───────────────────────────────────────
app/.dart_tool/
app/build/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.metadata
app/pubspec.lock
app/*.iml

# Pastas de plataforma (geradas pelo flutter create, não precisam subir)
app/android/
app/ios/
app/linux/
app/macos/
app/windows/

# Web — só os gerados; os estáticos (index.html, manifest.json) ficam
app/web/flutter_service_worker.js
app/web/flutter_bootstrap.js

# IntelliJ / Android Studio
app/.idea/

# ─── VS CODE ─────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/tasks.json
# Manter launch.json (tem o --dart-define necessário para rodar)
!app/.vscode/launch.json

# ─── CLAUDE CODE ─────────────────────────────────────────────────────────────
.claude/

# ─── VARIÁVEIS DE AMBIENTE ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── ARDUINO / WOKWI ─────────────────────────────────────────────────────────
smartscale/build/
*.bin
*.elf
*.map
*.hex